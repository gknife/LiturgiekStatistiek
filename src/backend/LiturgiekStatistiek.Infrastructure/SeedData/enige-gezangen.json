[
    {
        "number":  1,
        "title":  "Lofzang van Maria",
        "numberOfVerses":  7,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "Mijn ziel verheft Gods eer"
                       },
                       {
                           "number":  2,
                           "title":  "Want ziet, om ’s HEEREN daân"
                       },
                       {
                           "number":  3,
                           "title":  "Hoe heilig is Zijn Naam!"
                       },
                       {
                           "number":  4,
                           "title":  "Des HEEREN arm is sterk"
                       },
                       {
                           "number":  5,
                           "title":  "Die stout zijn op hun macht"
                       },
                       {
                           "number":  6,
                           "title":  "Hij heeft na lang geduld"
                       },
                       {
                           "number":  7,
                           "title":  "Zijn goedheid klom ten top:"
                       }
                   ]
    },
    {
        "number":  2,
        "title":  "Lofzang van Zacharias",
        "numberOfVerses":  5,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "Lof zij den God van Israël"
                       },
                       {
                           "number":  2,
                           "title":  "God had hun, tot hun troost, gemeld"
                       },
                       {
                           "number":  3,
                           "title":  "Hij speld’ ons, dat wij t’ allen tijd"
                       },
                       {
                           "number":  4,
                           "title":  "Dus wordt des HEEREN volk geleid"
                       },
                       {
                           "number":  5,
                           "title":  "Voor elk, die in het duister dwaalt"
                       }
                   ]
    },
    {
        "number":  3,
        "title":  "Lofzang van Simeon",
        "numberOfVerses":  2,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "Zo laat Gij, Heer’, Uw knecht"
                       },
                       {
                           "number":  2,
                           "title":  "Een licht, zo groot, zo schoon"
                       }
                   ]
    },
    {
        "number":  4,
        "title":  "Tien geboden",
        "numberOfVerses":  9,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "Mijn ziel, herdenk met heilig beven"
                       },
                       {
                           "number":  2,
                           "title":  "“Ik ben de HEER’, uw God en Koning"
                       },
                       {
                           "number":  3,
                           "title":  "Voor beeldendienst zult gij u wachten"
                       },
                       {
                           "number":  4,
                           "title":  "Misbruikt geenszins den Naam des HEEREN"
                       },
                       {
                           "number":  5,
                           "title":  "Gedenkt en viert, met vee en magen"
                       },
                       {
                           "number":  6,
                           "title":  "Gij zult uw ouders need’rig eren"
                       },
                       {
                           "number":  7,
                           "title":  "Gij zult niet doodslaan, noch u wreken!"
                       },
                       {
                           "number":  8,
                           "title":  "Uw hart zal nimmer iets begeren"
                       },
                       {
                           "number":  9,
                           "title":  "Och, of wij Uw geboôn volbrachten!"
                       }
                   ]
    },
    {
        "number":  5,
        "title":  "Gebed des Heeren",
        "numberOfVerses":  10,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "O allerhoogste Majesteit"
                       },
                       {
                           "number":  2,
                           "title":  "Geheiligd word’ Uw Naam; ai, geef"
                       },
                       {
                           "number":  3,
                           "title":  "Uw koninkrijk koom’ toch, o Heer’!"
                       },
                       {
                           "number":  4,
                           "title":  "Uw wil geschied’, Uw wil alleen"
                       },
                       {
                           "number":  5,
                           "title":  "Geef heden ons ons daag’lijks brood"
                       },
                       {
                           "number":  6,
                           "title":  "Vergeef ons onze schulden, HEER’!"
                       },
                       {
                           "number":  7,
                           "title":  "Leid ons in geen verzoeking ooit"
                       },
                       {
                           "number":  8,
                           "title":  "Verlos ons uit des bozen macht"
                       },
                       {
                           "number":  9,
                           "title":  "Want Uw is ’t Koninkrijk, o HEER’"
                       },
                       {
                           "number":  10,
                           "title":  "Ja, amen, trouwe Vader, ja"
                       }
                   ]
    },
    {
        "number":  6,
        "title":  "Twaalf Artikelen (berijming 1)",
        "numberOfVerses":  2,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "’k Geloof in God, den Vader, groot van macht"
                       },
                       {
                           "number":  2,
                           "title":  "’k Geloof ook in den Heil’gen Geest, dien w’ eren"
                       }
                   ]
    },
    {
        "number":  7,
        "title":  "Twaalf Artikelen (berijming 2)",
        "numberOfVerses":  4,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "’k Geloof in God, den Vader, die ’t heelal"
                       },
                       {
                           "number":  2,
                           "title":  "’k Geloof daarbij in Jezus, onzen Heer’"
                       },
                       {
                           "number":  3,
                           "title":  "Hij stond weer op, ons tot gerechtigheid"
                       },
                       {
                           "number":  4,
                           "title":  "’k Geloof ook in den Heil’gen Geest, Die één"
                       }
                   ]
    },
    {
        "number":  8,
        "title":  "Morgenzang",
        "numberOfVerses":  7,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "Wij danken U, barmhartig God"
                       },
                       {
                           "number":  2,
                           "title":  "Verleen ons, na genoten rust"
                       },
                       {
                           "number":  3,
                           "title":  "Dat wij ons ambt en plicht, o Heer’"
                       },
                       {
                           "number":  4,
                           "title":  "Zie op ons neder in genâ"
                       },
                       {
                           "number":  5,
                           "title":  "Verlicht ons hart, dat duister is"
                       },
                       {
                           "number":  6,
                           "title":  "Schenk Uwen zegen bij Uw Woord"
                       },
                       {
                           "number":  7,
                           "title":  "Troost allen, die in nood en smart"
                       }
                   ]
    },
    {
        "number":  9,
        "title":  "Avondzang",
        "numberOfVerses":  7,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "O grote Christus, eeuwig licht!"
                       },
                       {
                           "number":  2,
                           "title":  "Toon ons Uw goedheid en Uw macht"
                       },
                       {
                           "number":  3,
                           "title":  "Verkwik ons door een zoete rust"
                       },
                       {
                           "number":  4,
                           "title":  "Houd ons gemoed voor U bereid"
                       },
                       {
                           "number":  5,
                           "title":  "Bescherm ons, in den bangen tijd"
                       },
                       {
                           "number":  6,
                           "title":  "Behoed het ganse Christendom"
                       },
                       {
                           "number":  7,
                           "title":  "O Vader, dat Uw liefd’ ons blijk’"
                       }
                   ]
    },
    {
        "number":  10,
        "title":  "Bedezang voor de predikatie",
        "numberOfVerses":  1,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "O God, die onze Vader zijt"
                       }
                   ]
    },
    {
        "number":  11,
        "title":  "Bedezang voor het eten",
        "numberOfVerses":  1,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "O Vader, Die al ’t leven voedt"
                       }
                   ]
    },
    {
        "number":  12,
        "title":  "Dankzang na het eten",
        "numberOfVerses":  1,
        "verses":  [
                       {
                           "number":  1,
                           "title":  "O Heer’, wij danken U van harte"
                       }
                   ]
    }
]